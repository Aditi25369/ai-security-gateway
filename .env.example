# AI Security Gateway Configuration

# Service
GATEWAY_PORT=8080
WORKERS=1

# Security - Adversarial Hardening
BLOCK_THRESHOLD=0.85
RESPONSE_THRESHOLD=0.70
THRESHOLD_NOISE=0.03
API_KEY=your-secret-api-key-here
RATE_LIMIT_RPM=1000
SEMANTIC_RATE_LIMIT=true
EXPOSE_CONFIDENCE=false

# Models
TOXICITY_MODEL=unitary/toxic-bert
INJECTION_MODEL=protectai/deberta-v3-base-prompt-injection
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Performance
CACHE_ENABLED=true
CACHE_TTL=300

# Infrastructure
REDIS_URL=redis://localhost:6379
DB_TYPE=sqlite
DB_PATH=security_gateway.db
POSTGRES_URL=postgresql://user:pass@localhost/security_gateway
LOG_LEVEL=INFO

# Features
SCAN_RESPONSES=true
MULTIMODAL_ENABLED=true
CIRCUIT_BREAKER=true
SEMANTIC_SEARCH=true

# Prometheus Metrics
PROMETHEUS_ENABLED=true
